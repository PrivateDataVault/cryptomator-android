<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:gravity="center_horizontal"
	android:orientation="vertical">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="12dp"
		android:orientation="vertical">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="4dp">

			<ImageView
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/ic_checkmark" />

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:layout_weight="1"
				android:text="@string/screen_license_check_benefit_write_access" />
		</LinearLayout>

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="4dp">

			<ImageView
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/ic_checkmark" />

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:layout_weight="1"
				android:text="@string/screen_license_check_benefit_support" />
		</LinearLayout>

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:paddingVertical="4dp">

			<ImageView
				android:layout_width="20dp"
				android:layout_height="20dp"
				android:src="@drawable/ic_checkmark" />

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_marginStart="8dp"
				android:layout_weight="1"
				android:text="@string/screen_license_check_benefit_family_sharing" />
		</LinearLayout>

		<LinearLayout
			android:id="@+id/licenseEntryGroup"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<TextView
				android:id="@+id/tvLicenseLink"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:textAppearance="?attr/textAppearanceBody2" />

			<com.google.android.material.textfield.TextInputLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="@string/dialog_enter_license_title">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/etLicense"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:inputType="text" />

			</com.google.android.material.textfield.TextInputLayout>

		</LinearLayout>
	</LinearLayout>

	<Button
		android:id="@+id/btnPurchase"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="32dp"
		android:text="@string/screen_license_check_button_purchase" />

	<TextView
		android:id="@+id/tvUnlocked"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="16dp"
		android:gravity="center"
		android:text="@string/screen_license_check_already_unlocked"
		android:textAppearance="?attr/textAppearanceBody2"
		android:visibility="gone" />

</LinearLayout>
