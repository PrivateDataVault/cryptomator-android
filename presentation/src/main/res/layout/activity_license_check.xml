<?xml version="1.0" encoding="utf-8"?>
<org.cryptomator.presentation.ui.layout.ObscuredAwareCoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/activity_root_view"
	android:layout_width="match_parent"
	android:layout_height="match_parent">

	<com.google.android.material.appbar.AppBarLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content">

		<include
			android:id="@+id/mt_toolbar"
			layout="@layout/toolbar_layout" />

	</com.google.android.material.appbar.AppBarLayout>

	<ScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="24dp"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center_horizontal"
			android:orientation="vertical">

		<TextView
			android:id="@+id/tvLockedSubline"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="8dp"
			android:gravity="start"
			android:text="@string/screen_license_check_message"
			android:textAppearance="?attr/textAppearanceBody2" />

		<TextView
			android:id="@+id/tvBenefitsTitle"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="32dp"
			android:text="@string/screen_license_check_benefit_title"
			android:textAppearance="?attr/textAppearanceSubtitle1"
			android:textStyle="bold" />

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:orientation="vertical">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:orientation="horizontal"
				android:paddingVertical="4dp">

				<ImageView
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:src="@drawable/ic_checkmark" />

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="8dp"
					android:layout_weight="1"
					android:text="@string/screen_license_check_benefit_create_vaults" />
			</LinearLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:orientation="horizontal"
				android:paddingVertical="4dp">

				<ImageView
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:src="@drawable/ic_checkmark" />

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="8dp"
					android:layout_weight="1"
					android:text="@string/screen_license_check_benefit_write_access" />
			</LinearLayout>

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="center_vertical"
				android:orientation="horizontal"
				android:paddingVertical="4dp">

				<ImageView
					android:layout_width="20dp"
					android:layout_height="20dp"
					android:src="@drawable/ic_checkmark" />

				<TextView
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_marginStart="8dp"
					android:layout_weight="1"
					android:text="@string/screen_license_check_benefit_support" />
			</LinearLayout>
		</LinearLayout>

		<Button
			android:id="@+id/btnPurchase"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="32dp"
			android:text="@string/screen_license_check_button_purchase" />

		<TextView
			android:id="@+id/tvUnlocked"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="16dp"
			android:gravity="center"
			android:text="@string/screen_license_check_already_unlocked"
			android:textAppearance="?attr/textAppearanceBody2"
			android:visibility="gone" />

		<Button
			android:id="@+id/btnLater"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="8dp"
			android:text="@string/screen_license_check_button_later" />

		</LinearLayout>
	</ScrollView>
</org.cryptomator.presentation.ui.layout.ObscuredAwareCoordinatorLayout>
